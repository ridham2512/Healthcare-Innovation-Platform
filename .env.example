# ==========================================
# Healthcare AI (CureCloud) — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to git!

# --- Neon PostgreSQL Database ---
# Get this from: https://console.neon.tech → Your Project → Connection String
VITE_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Google Gemini AI ---
# Get this from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# --- Privy Authentication ---
# Get this from: https://dashboard.privy.io → Your App → App ID
VITE_PRIVY_APP_ID=your_privy_app_id_here
